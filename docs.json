{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Rendio",
  "description": "The PDF Developer Platform. Preview, diff, test, and observe your PDFs — not just generate them.",
  "colors": {
    "primary": "#f59e0b",
    "light": "#fbbf24",
    "dark": "#d97706"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://rendio.dev"
  },
  "appearance": {
    "default": "dark"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 700
    },
    "body": {
      "family": "Inter"
    }
  },
  "background": {
    "decoration": "gradient",
    "color": {
      "dark": "#0a0a0a",
      "light": "#fafaf9"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication",
              "account/dashboard"
            ]
          },
          {
            "group": "Rendering",
            "pages": [
              "concepts/how-it-works",
              "templates/html",
              "templates/tsx-react",
              "guides/screenshots",
              "guides/dynamic-data",
              "guides/preview-mode"
            ]
          },
          {
            "group": "Dev/Prod Parity",
            "pages": [
              "dev-prod-parity/overview",
              "dev-prod-parity/live-preview",
              "dev-prod-parity/highlight-changes",
              "dev-prod-parity/render-config",
              "dev-prod-parity/mock-data-tsx",
              "dev-prod-parity/using-rendio-config"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "guides/page-layout",
              "guides/headers-footers",
              "guides/page-breaks",
              "guides/images-and-fonts",
              "templates/styling-for-print",
              "guides/javascript-injection"
            ]
          },
          {
            "group": "SDKs",
            "pages": [
              "sdks/overview",
              "sdks/rendering",
              "sdks/error-handling",
              "sdks/retries-and-timeouts",
              "sdks/idempotency",
              "sdks/opentelemetry"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "guides/server-timing",
              "guides/performance"
            ]
          },
          {
            "group": "Integrate",
            "pages": [
              "use-cases/build-an-invoice",
              "use-cases/nextjs",
              "use-cases/express",
              "use-cases/fastapi",
              "use-cases/go-http"
            ]
          },
          {
            "group": "Account & Billing",
            "pages": [
              "concepts/plans-and-quotas",
              "account/spending-cap",
              "account/email-notifications",
              "resources/security-and-reliability",
              "resources/benchmarks",
              "resources/chromium-versions",
              "resources/changelog"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/errors"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/render",
              "api-reference/files",
              "api-reference/health"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://rendio.dev/dashboard",
          "icon": "chart-line"
        },
        {
          "anchor": "Status",
          "href": "https://status.rendio.dev",
          "icon": "signal-stream"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/rendio",
          "icon": "github"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/rendio",
      "x": "https://x.com/rendio_dev"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  }
}
