{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Rendio",
  "description": "HTML-to-PDF API for developers. Send HTML, get a PDF URL back.",
  "colors": {
    "primary": "#0F172A",
    "light": "#38BDF8",
    "dark": "#0EA5E9"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/how-it-works",
              "concepts/plans-and-quotas"
            ]
          },
          {
            "group": "Templates",
            "pages": [
              "templates/html",
              "templates/tsx-react",
              "templates/styling-for-print"
            ]
          },
          {
            "group": "SDKs",
            "pages": [
              "sdks/overview",
              "sdks/rendering",
              "sdks/error-handling",
              "sdks/retries-and-timeouts",
              "sdks/idempotency",
              "sdks/opentelemetry"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/dynamic-data",
              "guides/images-and-fonts",
              "guides/page-layout",
              "guides/page-breaks",
              "guides/headers-footers",
              "guides/screenshots",
              "guides/javascript-injection",
              "guides/performance"
            ]
          },
          {
            "group": "Use Cases",
            "pages": [
              "use-cases/build-an-invoice",
              "use-cases/nextjs",
              "use-cases/express"
            ]
          },
          {
            "group": "Tools",
            "pages": [
              "tools/vscode"
            ]
          },
          {
            "group": "Resources",
            "pages": [
              "resources/benchmarks",
              "resources/chromium-versions",
              "resources/changelog"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/errors"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/render",
              "api-reference/files",
              "api-reference/health"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://rendio.dev/dashboard",
          "icon": "chart-line"
        },
        {
          "anchor": "Status",
          "href": "https://status.rendio.dev",
          "icon": "signal-stream"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/rendio",
          "icon": "github"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/rendio",
      "x": "https://x.com/rendio_dev"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  }
}
